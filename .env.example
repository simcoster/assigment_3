NEBIUS_API_KEY=your_nebius_token_factory_api_key
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Smaller model for query routing
ROUTER_MODEL=Qwen/Qwen2.5-7B-Instruct

# Larger model for ReAct tool use and summarization
AGENT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Max ReAct loop steps (recursion_limit)
MAX_ITERATIONS=12

# Cached dataset path (relative to project root)
DATASET_PATH=data/bitext.parquet
