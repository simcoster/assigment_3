{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: loader.py",
      "type": "debugpy",
      "request": "launch",
      "module": "src.data.loader",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "args": ["--debug"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: loader.py (no sample fallback)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.data.loader",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "args": ["--debug", "--no-sample"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: download_data.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/download_data.py",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
